# =============================================================
# Multi-Agent Research Assistant — Environment Variables
# =============================================================
# Copy this file to .env and fill in your API keys.
#
# GROQ_API_KEY:
#   Sign up at https://console.groq.com → API Keys → Create
#   Free tier gives generous rate limits with Llama & Mixtral models.
#
# TAVILY_API_KEY:
#   Sign up at https://tavily.com → Dashboard → API Keys
#   Free tier: 1,000 searches / month.
# =============================================================

GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
